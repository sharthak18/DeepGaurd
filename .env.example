# ─────────────────────────────────────────────
#  DeepGuard — Environment Variables Template
#  Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# ── HuggingFace (REQUIRED) ───────────────────
# Sign up free at https://huggingface.co/
# Generate a "Read" token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sightengine (OPTIONAL) ───────────────────
# Sign up free at https://sightengine.com/ (2000 ops/month, no credit card)
# Dashboard → API credentials → copy your user & secret
SE_API_USER=
SE_API_SECRET=

# ── Tuning (OPTIONAL) ────────────────────────
# Max frames to sample per video (default: 10)
# DEEPGUARD_VIDEO_MAX_FRAMES=10

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# DEEPGUARD_LOG_LEVEL=INFO
